{
  "entities": {
    "Video": {
      "title": "Video",
      "description": "A video entity",
      "type": "object",
      "properties": {
        "title": { "type": "string", "maxLength": 100 },
        "description": { "type": "string", "maxLength": 500 },
        "url": { "type": "string", "maxLength": 200 },
        "tags": { "type": "array", "items": { "type": "string" }, "maxItems": 10 },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["title", "description", "url", "creatorId", "createdAt"]
    },
    "WatchLaterItem": {
      "title": "WatchLaterItem",
      "description": "An item in a user's watch later list",
      "type": "object",
      "properties": {
        "videoId": { "type": "string" },
        "addedAt": { "type": "timestamp" }
      },
      "required": ["videoId", "addedAt"]
    }
  },
  "firestore": {
    "/videos/{videoId}": {
      "schema": { "$ref": "#/entities/Video" },
      "description": "Global collection of videos"
    },
    "/users/{userId}/watchLater/{watchLaterId}": {
      "schema": { "$ref": "#/entities/WatchLaterItem" },
      "description": "Subcollection of videos added to watch later list"
    }
  }
}
